# Copy to .dev.vars for local Wrangler dev.
# Never commit real keys.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
SITE_URL=http://localhost:8788

# Block 7 Supabase order/inventory storage.
# Use the service role key ONLY in Cloudflare env vars / .dev.vars, never browser code.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me

# Admin dashboard MVP token. Make this long/random.
ADMIN_TOKEN=change-me-to-a-long-random-token

# Phase 4 — branded order-confirmation emails via Resend (optional).
# If unset, the webhook simply skips email. Verify your sending domain in Resend.
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=orders@yourdomain.com
# Optional email brand assets / links (leave blank to skip gracefully):
RESEND_LOGO_URL=
RESEND_HERO_GIF_URL=
DISCORD_INVITE_URL=https://discord.gg/JaaQuMrcTa

# Phase 5 — Resend webhook signing secret (whsec_...) for email analytics.
# From Resend dashboard → Webhooks. Enables /api/resend-webhook ingestion.
RESEND_WEBHOOK_SECRET=whsec_replace_me

# Phase 6 — Shippo shipping rates. Test key works for quoting; request a live
# key for production labels. Put the real key in .dev.vars, never here.
SHIPPO_API_KEY=shippo_test_replace_me

# Ship-from address used to quote rates (your warehouse / fulfillment address).
SHIP_FROM_NAME=R&G TCG
SHIP_FROM_STREET1=123 Example St
SHIP_FROM_CITY=Austin
SHIP_FROM_STATE=TX
SHIP_FROM_ZIP=78701
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=5125550100

# Phase 8 — Google Places address autocomplete on the checkout page (optional).
# Browser-safe, public key. Restrict it in Google Cloud Console to your domain
# (HTTP referrers) + the Maps JavaScript API + Places API only. If unset, the
# checkout falls back to plain manual address entry — nothing breaks.
GOOGLE_MAPS_API_KEY=AIzaSyDA0ATy7zyi8qtJhPoJkxydiwSA5Umavcs